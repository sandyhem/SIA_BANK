# NGINX / post-quantum proxy mode
# Services stay HTTP internally by default, and trust proxy headers.
# Source this file before starting services:
#   set -a && source /home/inba/SIA_BANK/tls-config/nginx-proxy.env && set +a

PQ_NGINX_ENABLED=true
PQ_NGINX_USE_SUDO=true
PQ_NGINX_SSL_ENABLED=true
PQ_NGINX_BIN=/usr/local/nginx-pq/sbin/nginx
PQ_NGINX_CONF=/usr/local/nginx-pq/conf/nginx.conf
PQ_NGINX_PID_FILE=/usr/local/nginx-pq/logs/nginx.pid
PQ_NGINX_TEMPLATE=/home/inba/SIA_BANK/tls-config/nginx-pq.conf.template
PQ_NGINX_HOST=pq-nginx.local
PQ_NGINX_PORT=443
PQ_NGINX_SERVER_CERT=/usr/local/nginx-pq/conf/server-mldsa65.crt
PQ_NGINX_SERVER_KEY=/usr/local/nginx-pq/conf/server-mldsa65.key
PQ_NGINX_CA_CERT=/usr/local/nginx-pq/conf/ca-mldsa87.crt
PQ_NGINX_CLIENT_VERIFY=optional
PQ_NGINX_VERIFY_DEPTH=2
PQ_NGINX_TLS_GROUPS=X25519MLKEM768
PQ_NGINX_SIGNATURE_ALGORITHMS=ML-DSA-65

AUTH_UPSTREAM_HOST=127.0.0.1
ACCOUNT_UPSTREAM_HOST=127.0.0.1
TRANSACTION_UPSTREAM_HOST=127.0.0.1

AUTH_SERVER_PORT=8083
ACCOUNT_SERVER_PORT=8081
TRANSACTION_SERVER_PORT=8082
TLS_CLIENT_ENABLED=false

AUTH_SERVICE_TLS_ENABLED=false
AUTH_SERVICE_KEY_STORE=
AUTH_SERVICE_KEY_STORE_PASSWORD=changeit
AUTH_SERVICE_KEY_STORE_TYPE=PKCS12

ACCOUNT_SERVICE_TLS_ENABLED=false
ACCOUNT_SERVICE_KEY_STORE=
ACCOUNT_SERVICE_KEY_STORE_PASSWORD=changeit
ACCOUNT_SERVICE_KEY_STORE_TYPE=PKCS12
# Point this to your NGINX or PQ proxy upstream if account-service calls auth through the proxy.
ACCOUNT_AUTH_SERVICE_URL=http://localhost:8083

TRANSACTION_SERVICE_TLS_ENABLED=false
TRANSACTION_SERVICE_KEY_STORE=
TRANSACTION_SERVICE_KEY_STORE_PASSWORD=changeit
TRANSACTION_SERVICE_KEY_STORE_TYPE=PKCS12
# Replace these with your NGINX / PQ proxy routes if needed.
TRANSACTION_ACCOUNT_SERVICE_URL=http://127.0.0.1:8081
TRANSACTION_AUTH_SERVICE_URL=http://localhost:8083/auth
