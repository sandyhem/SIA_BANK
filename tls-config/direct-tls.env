# Direct service-to-service TLS mode
# Source this file before starting services:
#   set -a && source /home/inba/SIA_BANK/tls-config/direct-tls.env && set +a

AUTH_SERVER_PORT=8083
ACCOUNT_SERVER_PORT=8081
TRANSACTION_SERVER_PORT=8082
TLS_CLIENT_ENABLED=true

AUTH_SERVICE_TLS_ENABLED=true
AUTH_SERVICE_KEY_STORE=file:/home/inba/SIA_BANK/certs/auth-service.p12
AUTH_SERVICE_KEY_STORE_PASSWORD=changeit
AUTH_SERVICE_KEY_STORE_TYPE=PKCS12

ACCOUNT_SERVICE_TLS_ENABLED=true
ACCOUNT_SERVICE_KEY_STORE=file:/home/inba/SIA_BANK/certs/account-service.p12
ACCOUNT_SERVICE_KEY_STORE_PASSWORD=changeit
ACCOUNT_SERVICE_KEY_STORE_TYPE=PKCS12
ACCOUNT_AUTH_SERVICE_URL=https://localhost:8083

TRANSACTION_SERVICE_TLS_ENABLED=true
TRANSACTION_SERVICE_KEY_STORE=file:/home/inba/SIA_BANK/certs/transaction-service.p12
TRANSACTION_SERVICE_KEY_STORE_PASSWORD=changeit
TRANSACTION_SERVICE_KEY_STORE_TYPE=PKCS12
TRANSACTION_ACCOUNT_SERVICE_URL=https://localhost:8081
TRANSACTION_AUTH_SERVICE_URL=https://localhost:8083/auth
